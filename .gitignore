# Cartridge & Cloud — Unity project
# Track: Assets, Packages, ProjectSettings, Documentation, Tools.
# Do not track generated Unity, IDE, cache, log, or local build files.

# Unity-generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset Store Tools
/[Aa]ssets/AssetStoreTools*

# Auto-generated Visual Studio / Rider / IDE files
.vs/
.idea/
.vscode/
.consulo/
.gradle/

# Autogenerated project files
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files for ignored folders/files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash and diagnostic files
sysinfo.txt
crashlytics-build.properties
*.stacktrace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Package and installer outputs
*.apk
*.aab
*.unitypackage

# Local secrets and environment overrides
.env
.env.*
!.env.example
*.keystore
*.jks

# Local evidence exports that should not be committed by default
Evidence/*.zip
Evidence/*.7z
Evidence/*.rar

# Preserve documentation and source evidence files
!Documentation/
!Documentation/**
!Tools/
!Tools/**
!Evidence/
!Evidence/**/*.md
!Evidence/**/*.csv
!Evidence/**/*.json
!Evidence/**/*.png
