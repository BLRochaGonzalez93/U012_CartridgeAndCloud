# Normalize text files across development environments.
* text=auto

# Source code and project documentation.
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Unity text-serialized assets.
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable text eol=lf
*.mask text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.renderTexture text eol=lf
*.spriteatlas text eol=lf
*.terrainlayer text eol=lf
*.lighting text eol=lf

# Shaders and UI.
*.shader text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.uxml text eol=lf
*.uss text eol=lf

